{
  "name": "@ondrej-svec/hog",
  "version": "1.32.0",
  "description": "The Rails of agent-assisted development — TDD-enforced AI pipelines with structural role separation",
  "author": "Ondrej Svec",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ondrej-svec/hog.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "hog": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup && mkdir -p dist/engine && cp -r src/engine/fallback-prompts dist/engine/",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "check": "biome check src/",
    "check:fix": "biome check --write src/",
    "lint": "biome lint src/",
    "format": "biome format --write src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci": "npm run typecheck && npm run check && npm run test",
    "prepublishOnly": "npm run ci && npm run build"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "cli",
    "ai-agents",
    "tdd",
    "pipeline",
    "code-generation",
    "developer-tools",
    "agent-orchestration",
    "tui"
  ],
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.0.18",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "@inquirer/prompts": "^8.2.1",
    "chalk": "^5.6.2",
    "chrono-node": "^2.9.0",
    "commander": "^14.0.3",
    "fzf": "^0.5.2",
    "ink": "^6.7.0",
    "react": "^19.2.4",
    "zod": "^4.3.6"
  }
}
